<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Alpheratz.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Alpheratz.Presentation.Views"
    Title="Alpheratz"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <TitleBar x:Name="AppTitleBar" Title="Alpheratz">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Margin="0,48,0,0">
            <views:ShellPage x:Name="ShellPageHost" />
        </Grid>
    </Grid>
</Window>
