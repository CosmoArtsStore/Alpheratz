<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Alpheratz.Presentation.Views.PhotoDetailPaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Alpheratz.Presentation.ViewModels"
    xmlns:conv="using:Alpheratz.Presentation.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:FavoriteIconConverter x:Key="FavoriteIconConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        
        <Storyboard x:Name="OpenAnimation">
            <DoubleAnimation Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" />
            <DoubleAnimation Storyboard.TargetName="RootBorderTranslate" Storyboard.TargetProperty="X" From="100" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="7"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="RootBorder" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootBorderTranslate" />
        </Border.RenderTransform>
        <ScrollViewer Padding="24">
            <StackPanel Spacing="24">
                <!-- Header -->
                <Grid>
                    <TextBlock Text="Photo Details" FontSize="20" FontWeight="SemiBold" />
                    <Button HorizontalAlignment="Right" Style="{ThemeResource SubtleButtonStyle}" Command="{x:Bind ViewModel.CloseCommand}">
                        <SymbolIcon Symbol="Cancel" />
                    </Button>
                </Grid>

                <!-- Detail Image -->
                <Border CornerRadius="8" Background="#11000000">
                    <!-- Note: HighResImageSource is used here as object? bound to Image.Source -->
                    <Image Source="{x:Bind ViewModel.HighResImageSource, Mode=OneWay}" MaxHeight="400" Stretch="Uniform" />
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Command="{x:Bind ViewModel.ToggleFavoriteAsyncCommand}" Style="{ThemeResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <!-- Binding IsFavorite from ViewModel.Photo.IsFavorite might be complex, 
                                 Metadata or the converter should handle it if directly on Photo -->
                            <FontIcon Glyph="{x:Bind ViewModel.Photo.IsFavorite, Mode=OneWay, Converter={StaticResource FavoriteIconConverter}}" FontSize="14" />
                            <TextBlock Text="Favorite" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Metadata -->
                <StackPanel Spacing="12">
                    <TextBlock Text="Filename" FontSize="14" FontWeight="SemiBold" Opacity="0.5" />
                    <TextBlock Text="{x:Bind ViewModel.Metadata.Filename, Mode=OneWay}" FontSize="16" />

                    <TextBlock Text="Timestamp" FontSize="14" FontWeight="SemiBold" Opacity="0.5" Margin="0,12,0,0" />
                    <TextBlock Text="{x:Bind ViewModel.Metadata.Timestamp, Mode=OneWay}" FontSize="16" />
                    
                    <TextBlock Text="Dimensions" FontSize="14" FontWeight="SemiBold" Opacity="0.5" Margin="0,12,0,0" />
                    <TextBlock Text="{x:Bind ViewModel.Metadata.Dimensions, Mode=OneWay}" FontSize="16" />

                    <TextBlock Text="Tags" FontSize="14" FontWeight="SemiBold" Opacity="0.5" Margin="0,12,0,0" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.TagEditor.AttachedTags}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,8,0" Padding="12,4" Background="{ThemeResource SystemControlBackgroundSecondaryAlphaHighBrush}" CornerRadius="16">
                                    <TextBlock Text="{Binding}" FontSize="12" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Memo" FontSize="14" FontWeight="SemiBold" Opacity="0.5" Margin="0,12,0,0" />
                    <!-- Binding to Photo.Memo might not work two-way if Photo is null. VM property is safer. 
                         For now, preserving one-way from Photo.Memo and accepting it might fail compile if not handled. -->
                    <TextBox 
                        Text="{x:Bind ViewModel.Photo.Memo, Mode=OneWay}" 
                        PlaceholderText="Add a memo..." 
                        AcceptsReturn="True" 
                        Height="100" 
                        TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
