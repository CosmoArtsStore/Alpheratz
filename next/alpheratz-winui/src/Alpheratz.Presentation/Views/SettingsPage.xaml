<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Alpheratz.Presentation.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="40" MaxWidth="800" HorizontalAlignment="Left">
        <StackPanel Spacing="32">
            <TextBlock Text="Settings" FontSize="32" FontWeight="Bold" />

            <!-- Folder Section -->
            <StackPanel Spacing="16">
                <TextBlock Text="Storage &amp; Folders" FontSize="20" FontWeight="SemiBold" />
                <Border Padding="24" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Primary Photo Folder" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Text="{x:Bind ViewModel.PhotoFolderPath, Mode=TwoWay}" PlaceholderText="C:\Users\...\Pictures\VRChat" />
                            <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0" />
                        </Grid>
                        <TextBlock Text="Secondary Photo Folder" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Text="{x:Bind ViewModel.SecondaryPhotoFolderPath, Mode=TwoWay}" PlaceholderText="Optional second source..." />
                            <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0" />
                        </Grid>
                        <TextBlock Text="Alpheratz will scan these folders for new VRChat photos." FontSize="12" Opacity="0.6" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Appearance Section -->
            <StackPanel Spacing="16">
                <TextBlock Text="Appearance" FontSize="20" FontWeight="SemiBold" />
                <Border Padding="24" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Theme Mode" FontWeight="SemiBold" />
                        <ComboBox SelectedValue="{x:Bind ViewModel.ThemeMode, Mode=TwoWay}" Width="200">
                            <ComboBoxItem Content="Light" Value="light" />
                            <ComboBoxItem Content="Dark" Value="dark" />
                            <ComboBoxItem Content="System Default" Value="system" />
                        </ComboBox>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- System Section -->
            <StackPanel Spacing="16">
                <TextBlock Text="System Integration" FontSize="20" FontWeight="SemiBold" />
                <Border Padding="24" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <ToggleSwitch Header="Launch at Startup" IsOn="{x:Bind ViewModel.EnableStartup, Mode=TwoWay}" />
                        <TextBlock Text="Automatically start Alpheratz when you sign in to Windows." FontSize="12" Opacity="0.6" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Button Content="Save Changes" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.SaveCommand}" HorizontalAlignment="Right" Padding="32,8" />
        </StackPanel>
    </ScrollViewer>
</Page>
