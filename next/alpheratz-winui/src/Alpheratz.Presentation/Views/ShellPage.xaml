<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Alpheratz.Presentation.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Alpheratz.Presentation.Views"
    mc:Ignorable="d">
    <Grid>
        <Grid RowDefinitions="Auto,*">
            <Border Padding="16,12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Alpheratz Shell" />
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="280,*">
                <Border Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Navigation" />
                        <ListView
                            x:Name="NavigationList"
                            SelectionMode="Single"
                            SelectionChanged="OnNavigationSelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Frame x:Name="ShellFrame" Grid.Column="1" />
            </Grid>
        </Grid>

        <Border
            x:Name="DialogOverlay"
            Background="#990C1118"
            Visibility="Collapsed">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border
                    Width="420"
                    Padding="24"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="24">
                    <StackPanel Spacing="12">
                        <TextBlock x:Name="DialogTitleText" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="DialogMessageText" Opacity="0.72" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Content="Cancel" />
                            <Button Content="OK" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <InfoBar
            x:Name="ToastHost"
            Margin="0,56,24,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            IsOpen="False"
            IsClosable="False"
            Severity="Informational"
            Title="Toast foundation" />

        <!-- Scan Progress Overlay -->
        <Border x:Name="ScanProgressOverlay" 
                Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="#CC000000" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="64" Height="64" />
                <TextBlock Text="Scanning Folders..." FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.ScanStatus, Mode=OneWay}" Opacity="0.8" HorizontalAlignment="Center" />
                <ProgressBar Value="{x:Bind ViewModel.ScanProgress, Mode=OneWay}" Width="300" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
