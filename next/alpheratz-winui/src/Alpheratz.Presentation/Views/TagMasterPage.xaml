<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Alpheratz.Presentation.Views.TagMasterPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Alpheratz.Presentation.ViewModels"
    mc:Ignorable="d">

    <ScrollViewer Padding="40" MaxWidth="800" HorizontalAlignment="Left">
        <StackPanel Spacing="32">
            <TextBlock Text="Tag Management" FontSize="32" FontWeight="Bold" />

            <Border Padding="24" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Add New Tag" FontSize="18" FontWeight="SemiBold" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox PlaceholderText="e.g., Night, Portrait, Action" Text="{x:Bind ViewModel.NewTagName, Mode=TwoWay}" />
                        <Button Grid.Column="1" Content="Add Tag" Command="{x:Bind ViewModel.AddTagAsyncCommand}" Style="{ThemeResource AccentButtonStyle}" Margin="12,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="Existing Tags" FontSize="20" FontWeight="SemiBold" />
            
            <ItemsControl ItemsSource="{x:Bind ViewModel.Tags}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TagSummaryViewModel">
                        <Border Padding="16,12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                            <Grid>
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <Button HorizontalAlignment="Right" Style="{ThemeResource SubtleButtonStyle}" 
                                        Command="{Binding ElementName=PageRoot, Path=ViewModel.DeleteTagAsyncCommand}" 
                                        CommandParameter="{Binding}">
                                    <SymbolIcon Symbol="Delete" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
